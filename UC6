class FleetReport {
    Vehicle vehicle;
    int totalFuel;
    boolean withinLimit;

    public FleetReport(Vehicle vehicle, int totalFuel, boolean withinLimit) {
        this.vehicle = vehicle;
        this.totalFuel = totalFuel;
        this.withinLimit = withinLimit;
    }

    public void print() {
        System.out.println("Model: " + vehicle.model);
        System.out.println("Total Fuel: " + totalFuel);
        System.out.println("Emission Compliance: " + withinLimit);
    }
}
