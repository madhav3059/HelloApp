ZoneDesk (Desk)
class ZoneDesk {
    Vehicle vehicle;

    public ZoneDesk(Vehicle vehicle) {
        this.vehicle = vehicle;
    }

    public void checkType(String[] allowedTypes) {
        boolean allowed = false;

        for (int i = 0; i < allowedTypes.length; i++) {
            if (vehicle.type.equals(allowedTypes[i])) {
                allowed = true;
                break;
            }
        }

        if (allowed) {
            System.out.println(vehicle.model + " is allowed in this zone.");
        } else {
            System.out.println("Type not permitted.");
        }
    }
